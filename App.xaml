        <Style TargetType="{x:Type Window}">
            <Setter Property="Background" Value="{StaticResource MaterialBackground}" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="TextElement.Foreground" Value="{StaticResource MaterialTextPrimary}" />
        </Style>

        <Style x:Key="WindowCaptionButton" TargetType="{x:Type Button}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MaterialTextPrimary}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20" />
                            <Border x:Name="StateLayer"
                                    Background="{StaticResource MaterialPrimary}"
                                    CornerRadius="20"
                                    Opacity="0" />
                            <ContentPresenter x:Name="IconPresenter"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StateLayer" Property="Opacity" Value="0.12" />
                                <Setter Property="Foreground" Value="{StaticResource MaterialTextPrimary}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="StateLayer" Property="Opacity" Value="0.18" />
                                <Setter Property="Foreground" Value="{StaticResource MaterialOnPrimary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource MaterialDisabled}" />
                                <Setter TargetName="StateLayer" Property="Opacity" Value="0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCaptionCloseButton"
               TargetType="{x:Type Button}"
               BasedOn="{StaticResource WindowCaptionButton}">
            <Setter Property="Foreground" Value="{StaticResource MaterialError}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20" />
                            <Border x:Name="StateLayer"
                                    Background="{StaticResource MaterialError}"
                                    CornerRadius="20"
                                    Opacity="0" />
                            <ContentPresenter x:Name="IconPresenter"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StateLayer" Property="Opacity" Value="0.14" />
                                <Setter Property="Foreground" Value="{StaticResource MaterialError}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="StateLayer" Property="Opacity" Value="0.22" />
                                <Setter Property="Foreground" Value="{StaticResource MaterialOnPrimary}" />
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource MaterialError}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource MaterialDisabled}" />
                                <Setter TargetName="StateLayer" Property="Opacity" Value="0" />
                                <Setter TargetName="Root" Property="Background" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Control}">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        </Style>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="MaterialTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MaterialTextPrimary}" />
        </Style>

        <Style x:Key="MaterialSubtitle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource MaterialTextSecondary}" />
        </Style>

        <Style x:Key="MaterialSection" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource MaterialTextPrimary}" />
        </Style>

        <Style x:Key="MaterialLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MaterialTextSecondary}" />
        </Style>

        <Style TargetType="{x:Type controls:MaterialButton}">
            <Setter Property="Background" Value="{StaticResource MaterialPrimary}" />
            <Setter Property="Foreground" Value="{StaticResource MaterialOnPrimary}" />
            <Setter Property="Padding" Value="16,9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinHeight" Value="40" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:MaterialButton}">
                        <ControlTemplate.Resources>
                            <Style TargetType="{x:Type TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}">
                                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}" />
                            </Style>
                        </ControlTemplate.Resources>
                        <Grid ClipToBounds="False">
                            <Rectangle x:Name="ShadowLayer"
                                       RadiusX="16"
                                       RadiusY="16"
                                       Fill="{TemplateBinding Background}">
                                <Rectangle.Effect>
                                    <DropShadowEffect BlurRadius="10"
                                                      ShadowDepth="1"
                                                      Opacity="0.2"
                                                      Color="#22000000"
                                                      RenderingBias="Performance" />
                                </Rectangle.Effect>
                            </Rectangle>
                            <Border x:Name="ButtonBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource CornerButton}"
                                    ClipToBounds="True">
                                <Grid x:Name="PART_RippleHost">
                                    <Grid.Clip>
                                        <RectangleGeometry RadiusX="{Binding Source={StaticResource CornerButton}, Path=TopLeft}"
                                                           RadiusY="{Binding Source={StaticResource CornerButton}, Path=TopLeft}">
                                            <RectangleGeometry.Rect>
                                                <MultiBinding Converter="{StaticResource RoundedRectConverter}">
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualWidth" />
                                                    <Binding RelativeSource="{RelativeSource AncestorType=Border}" Path="ActualHeight" />
                                                </MultiBinding>
                                            </RectangleGeometry.Rect>
                                        </RectangleGeometry>
                                    </Grid.Clip>
                                    <Border x:Name="StateLayer"
                                            Background="{TemplateBinding Foreground}"
                                            Opacity="0"
                                            CornerRadius="{StaticResource CornerButton}" />
                                    <Ellipse x:Name="PART_Ripple"
                                             RenderTransformOrigin="0.5,0.5"
                                             Opacity="0"
                                             Fill="{TemplateBinding Foreground}"
                                             Width="48"
                                             Height="48">
                                        <Ellipse.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform x:Name="PART_RippleScale" ScaleX="0" ScaleY="0" />
                                                <TranslateTransform x:Name="PART_RippleTranslate" />
                                            </TransformGroup>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"
                                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Background" Value="Transparent">
                                <Setter TargetName="ShadowLayer" Property="Opacity" Value="0" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StateLayer" Property="Opacity" Value="0.08" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="StateLayer" Property="Opacity" Value="0.12" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="StateLayer" Property="Opacity" Value="0.12" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource MaterialDisabled}" />
                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource MaterialSurfaceVariant}" />
                                <Setter TargetName="StateLayer" Property="Opacity" Value="0" />
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PART_RippleScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="0"
                                                         To="5"
                                                         Duration="0:0:0.5"
                                                         AccelerationRatio="0.3"
                                                         DecelerationRatio="0.7" />
                                        <DoubleAnimation Storyboard.TargetName="PART_RippleScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="0"
                                                         To="5"
                                                         Duration="0:0:0.5"
                                                         AccelerationRatio="0.3"
                                                         DecelerationRatio="0.7" />
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PART_Ripple"
                                                                       Storyboard.TargetProperty="Opacity">
                                            <DiscreteDoubleKeyFrame Value="0.18" KeyTime="0:0:0" />
                                            <LinearDoubleKeyFrame Value="0.08" KeyTime="0:0:0.2" />
                                            <LinearDoubleKeyFrame Value="0" KeyTime="0:0:0.5" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MaterialTonalButton" TargetType="{x:Type controls:MaterialButton}" BasedOn="{StaticResource {x:Type controls:MaterialButton}}">
            <Setter Property="Background" Value="{StaticResource MaterialPrimaryContainer}" />
            <Setter Property="Foreground" Value="{StaticResource MaterialOnPrimaryContainer}" />
        </Style>

        <Style x:Key="MaterialTonalTopBarButton" TargetType="{x:Type controls:MaterialButton}" BasedOn="{StaticResource MaterialTonalButton}">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="16,4" />
        </Style>

        <Style x:Key="MaterialOutlinedButton" TargetType="{x:Type controls:MaterialButton}" BasedOn="{StaticResource {x:Type controls:MaterialButton}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MaterialPrimary}" />
            <Setter Property="BorderBrush" Value="{StaticResource MaterialOutlineVariant}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MaterialElevatedDangerButton" TargetType="{x:Type controls:MaterialButton}" BasedOn="{StaticResource {x:Type controls:MaterialButton}}">
            <Setter Property="Background" Value="{StaticResource MaterialSurfaceContainerHigh}" />
            <Setter Property="Foreground" Value="{StaticResource MaterialError}" />
            <Setter Property="BorderBrush" Value="{StaticResource MaterialOutlineVariant}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MaterialTextButton" TargetType="{x:Type controls:MaterialButton}" BasedOn="{StaticResource {x:Type controls:MaterialButton}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MaterialPrimary}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style x:Key="MaterialDangerButton" TargetType="{x:Type controls:MaterialButton}" BasedOn="{StaticResource {x:Type controls:MaterialButton}}">
            <Setter Property="Background" Value="{StaticResource MaterialError}" />
            <Setter Property="Foreground" Value="{StaticResource MaterialOnPrimary}" />
        </Style>

        <Style x:Key="MaterialIconButton" TargetType="{x:Type controls:MaterialButton}" BasedOn="{StaticResource {x:Type controls:MaterialButton}}">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource MaterialSurfaceVariant}" />
            <Setter Property="Foreground" Value="{StaticResource MaterialTextPrimary}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="{x:Type controls:MaterialCard}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:MaterialCard}">
                        <Border Background="{StaticResource MaterialSurfaceContainerHigh}"
                                CornerRadius="{StaticResource CornerLarge}"
                                Padding="18"
                                BorderBrush="{StaticResource MaterialOutlineVariant}"
                                BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="14"
                                                  ShadowDepth="1"
                                                  Opacity="0.1"
                                                  Color="#14000000"
                                                  RenderingBias="Performance" />
                            </Border.Effect>
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type controls:MaterialTextBox}">
            <Setter Property="Background" Value="{StaticResource MaterialSurface}" />
            <Setter Property="BorderBrush" Value="{StaticResource MaterialOutline}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:MaterialTextBox}">
                        <Grid>
                            <Border x:Name="InputBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{StaticResource CornerSmall}" />
                            <TextBlock x:Name="Placeholder"
                                       Text="{TemplateBinding Tag}"
                                       Foreground="{StaticResource MaterialTextSecondary}"
                                       Margin="12,8,12,8"
                                       Visibility="Collapsed"
                                       IsHitTestVisible="False" />
                            <ScrollViewer x:Name="PART_ContentHost" Margin="12,10,12,10" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{StaticResource MaterialPrimary}" />
                                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource MaterialSurfaceVariant}" />
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource MaterialDisabled}" />
                                <Setter TargetName="InputBorder" Property="Background" Value="{StaticResource MaterialSurfaceVariant}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type controls:MaterialToggle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:MaterialToggle}">
                        <Grid Width="44" Height="24">
                            <Border x:Name="Track"
                                    Background="{StaticResource MaterialOutlineVariant}"
                                    CornerRadius="12" />
                            <Ellipse x:Name="Thumb"
                                     Width="20"
                                     Height="20"
                                     Fill="{StaticResource MaterialSurface}"
                                     Margin="2,2,22,2" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource MaterialPrimaryContainer}" />
                                <Setter TargetName="Thumb" Property="Margin" Value="22,2,2,2" />
                                <Setter TargetName="Thumb" Property="Fill" Value="{StaticResource MaterialPrimary}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MaterialLogBox" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource MaterialSurfaceVariant}" />
            <Setter Property="BorderBrush" Value="{StaticResource MaterialOutlineVariant}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MaterialTextPrimary}" />
        </Style>

        <Style TargetType="{x:Type controls:MaterialScrollBar}">
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MaterialOutlineVariant}" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:MaterialScrollBar}">
                        <ControlTemplate.Resources>
                            <Style TargetType="{x:Type RepeatButton}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type RepeatButton}">
                                            <Border Background="Transparent" />
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <Style TargetType="{x:Type Thumb}">
                                <Setter Property="MinHeight" Value="24" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                            <Border x:Name="ThumbBorder"
                                                    Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ScrollBar}}"
                                                    CornerRadius="4"
                                                    Margin="2,2">
                                                <Border.OpacityMask>
                                                    <SolidColorBrush Color="White" Opacity="0.7" />
                                                </Border.OpacityMask>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource MaterialPrimary}" />
                                                    <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.75" />
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource MaterialPrimaryDark}" />
                                                    <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ControlTemplate.Resources>
                        <Grid Background="{TemplateBinding Background}"
                              VerticalAlignment="Stretch"
                              HorizontalAlignment="Stretch">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Orientation="{TemplateBinding Orientation}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Value="{TemplateBinding Value}"
                                   ViewportSize="{TemplateBinding ViewportSize}"
                                   VerticalAlignment="Stretch"
                                   HorizontalAlignment="Stretch">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="10" />
                                <Setter Property="MinHeight" Value="10" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollViewer}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Margin="{TemplateBinding Padding}"
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}" />
                            <controls:MaterialScrollBar x:Name="PART_VerticalScrollBar"
                                                        Grid.Row="0"
                                                        Grid.Column="1"
                                                        Orientation="Vertical"
                                                        Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                                        Minimum="0"
                                                        Maximum="{TemplateBinding ScrollableHeight}"
                                                        ViewportSize="{TemplateBinding ViewportHeight}"
                                                        Value="{TemplateBinding VerticalOffset}" />
                            <controls:MaterialScrollBar x:Name="PART_HorizontalScrollBar"
                                                        Grid.Row="1"
                                                        Grid.Column="0"
                                                        Orientation="Horizontal"
                                                        Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                                        Minimum="0"
                                                        Maximum="{TemplateBinding ScrollableWidth}"
                                                        ViewportSize="{TemplateBinding ViewportWidth}"
                                                        Value="{TemplateBinding HorizontalOffset}" />
                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    Background="Transparent"
                                    Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ComputedVerticalScrollBarVisibility}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type controls:MaterialProgressBar}">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Thickness" Value="4" />
            <Setter Property="SweepAngle" Value="270" />
            <Setter Property="TrackBrush" Value="{StaticResource MaterialSurfaceVariant}" />
            <Setter Property="IndicatorBrush" Value="{StaticResource MaterialPrimary}" />
            <Style.Triggers>
                <Trigger Property="IsIndeterminate" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard x:Name="ProgressIndeterminate">
                            <Storyboard RepeatBehavior="Forever">
                                <DoubleAnimation Storyboard.TargetProperty="Angle"
                                                 From="0" To="360" Duration="0:0:1.1" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="ProgressIndeterminate" />
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MaterialPage" TargetType="{x:Type Grid}">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="12" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.3" />
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                             From="12" To="0" Duration="0:0:0.3" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
