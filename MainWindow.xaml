<Window x:Class="MAS_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MAS_GUI"
        xmlns:controls="clr-namespace:MAS_GUI.Controls"
        mc:Ignorable="d"
        Title="MAS GUI"
        Height="760"
        Width="460"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="{StaticResource MaterialSurfaceContainer}"
            CornerRadius="{StaticResource CornerLarge}"
            Margin="20"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="4"
                              Opacity="0.26"
                              Color="#33000000"
                              RenderingBias="Performance" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border x:Name="TitleBar"
                    Background="{StaticResource MaterialSurfaceContainerHigh}"
                    BorderBrush="{StaticResource MaterialOutlineVariant}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="20,20,0,0"
                    MinHeight="56"
                    MouseLeftButtonDown="OnTitleBarMouseLeftButtonDown">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 顶部独立系统按钮栏 -->
                <Grid Grid.Row="0" Margin="0,0,4,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right">
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource WindowCaptionButton}"
                                Click="OnMinimizeClick">
                            <controls:MaterialIcon Geometry="{StaticResource IconMinimize}"
                                                   Width="10" Height="10"
                                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                        <Button x:Name="MaximizeButton"
                                Style="{StaticResource WindowCaptionButton}"
                                Click="OnMaximizeClick">
                            <controls:MaterialIcon Geometry="{StaticResource IconMaximize}"
                                                   Width="10" Height="10"
                                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                        <Button x:Name="CloseButton"
                                Style="{StaticResource WindowCaptionCloseButton}"
                                Click="OnCloseClick">
                            <controls:MaterialIcon Geometry="{StaticResource IconClose}"
                                                   Width="10" Height="10"
                                                   Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- 下方 MD3 头部内容，不受系统按钮布局影响 -->
                <Grid Grid.Row="1" Margin="16,10,16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Grid.Column="0"
                            Grid.RowSpan="2"
                            Width="40"
                            Height="40"
                            CornerRadius="20"
                            Background="{StaticResource MaterialPrimaryContainer}"
                            VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10"
                                              ShadowDepth="1"
                                              Opacity="0.2"
                                              Color="#22000000"
                                              RenderingBias="Performance" />
                        </Border.Effect>
                        <controls:MaterialIcon Geometry="{StaticResource IconToolbox}"
                                               Fill="{StaticResource MaterialOnPrimaryContainer}"
                                               Width="20"
                                               Height="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                    </Border>

                    <TextBlock Grid.Row="0"
                               Grid.Column="1"
                               Text="MAS GUI"
                               Style="{StaticResource MaterialTitle}"
                               Margin="12,2,12,0"
                               VerticalAlignment="Center" />

                    <controls:SayingWidget Grid.Row="1"
                                           Grid.Column="1"
                                           Margin="12,4,12,0" />

                    <StackPanel Grid.Row="0"
                                Grid.Column="2"
                                Grid.RowSpan="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <controls:MaterialButton x:Name="AdvancedButton"
                                                 Style="{StaticResource MaterialTonalTopBarButton}"
                                                 Content="高级"
                                                 Width="64"
                                                 Click="OnShowAdvanced" />
                        <controls:MaterialButton x:Name="BackButton"
                                                 Style="{StaticResource MaterialTonalTopBarButton}"
                                                 Content="返回"
                                                 Width="64"
                                                 Visibility="Collapsed"
                                                 Click="OnShowMain" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" x:Name="ActionsPanel">
            <Grid x:Name="MainPanel" Visibility="Visible">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24,0">
                    <controls:MaterialCard Width="320">
                        <StackPanel HorizontalAlignment="Center">
                            <Border Width="56" Height="56" CornerRadius="28" Background="{StaticResource MaterialPrimaryContainer}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10"
                                                      ShadowDepth="1"
                                                      Opacity="0.2"
                                                      Color="#22000000"
                                                      RenderingBias="Performance" />
                                </Border.Effect>
                                <controls:MaterialIcon Geometry="{StaticResource IconWindowsMd3}" Fill="{StaticResource MaterialOnPrimaryContainer}" Width="26" Height="26" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="一键激活" Style="{StaticResource MaterialSection}" HorizontalAlignment="Center" Margin="0,16,0,0" />
                            <TextBlock Text="自动检测Windows和已安装Office套件并激活" Style="{StaticResource MaterialSubtitle}" Margin="0,6,0,20" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Width="260" />
                            <controls:MaterialButton Width="220" Height="44" Click="OnRunTsforgeAll">
                                <StackPanel Orientation="Horizontal">
                                    <controls:MaterialIcon Geometry="{StaticResource IconBolt}" Fill="{StaticResource MaterialOnPrimary}" Width="18" Height="18" Margin="0,0,8,0" />
                                    <TextBlock Text="一键激活" Foreground="{StaticResource MaterialOnPrimary}" />
                                </StackPanel>
                            </controls:MaterialButton>
                        </StackPanel>
                    </controls:MaterialCard>
                </StackPanel>
            </Grid>

            <ScrollViewer x:Name="AdvancedPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="20,20,20,24">
                    <StackPanel Orientation="Horizontal">
                        <controls:MaterialIcon Geometry="{StaticResource IconSettings}" Fill="{StaticResource MaterialTextSecondary}" Width="18" Height="18" Margin="0,2,8,0" />
                        <TextBlock Text="高级功能" Style="{StaticResource MaterialSection}" />
                    </StackPanel>
                    <TextBlock Text="全部功能与参数设置集中在此页。" Style="{StaticResource MaterialSubtitle}" Margin="0,6,0,20" />

                    <controls:MaterialCard Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <controls:MaterialIcon Geometry="{StaticResource IconWindows}" Fill="{StaticResource MaterialTextSecondary}" Width="18" Height="18" Margin="0,2,8,0" />
                                <TextBlock Text="Windows" FontSize="15" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <controls:MaterialButton Content="HWID" Width="110" Height="36" Style="{StaticResource MaterialTonalButton}" Click="OnRunHwid" />
                                <controls:MaterialButton Content="TSforge 激活" Width="140" Height="36" Margin="12,0,0,0" Style="{StaticResource MaterialTonalButton}" Click="OnRunTsforgeAll" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <controls:MaterialButton Content="TSforge ESU" Width="140" Height="36" Style="{StaticResource MaterialTonalButton}" Click="OnRunTsforgeEsu" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Border CornerRadius="{StaticResource CornerButton}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10"
                                                          ShadowDepth="1"
                                                          Opacity="0.2"
                                                          Color="#22000000"
                                                          RenderingBias="Performance" />
                                    </Border.Effect>
                                    <controls:MaterialButton Content="卸载" Width="90" Height="36" Style="{StaticResource MaterialOutlinedButton}" Click="OnRunWindowsUninstall" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </controls:MaterialCard>

                    <controls:MaterialCard Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <controls:MaterialIcon Geometry="{StaticResource IconOffice}" Fill="{StaticResource MaterialTextSecondary}" Width="18" Height="18" Margin="0,2,8,0" />
                                <TextBlock Text="Office" FontSize="15" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <controls:MaterialButton Content="Ohook" Width="110" Height="36" Style="{StaticResource MaterialTonalButton}" Click="OnRunOhook" />
                                <Border CornerRadius="{StaticResource CornerButton}" Margin="12,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10"
                                                          ShadowDepth="1"
                                                          Opacity="0.2"
                                                          Color="#22000000"
                                                          RenderingBias="Performance" />
                                    </Border.Effect>
                                    <controls:MaterialButton Content="卸载" Width="90" Height="36" Style="{StaticResource MaterialOutlinedButton}" Click="OnRunOhookUninstall" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </controls:MaterialCard>

                    <controls:MaterialCard Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <controls:MaterialIcon Geometry="{StaticResource IconKey}" Fill="{StaticResource MaterialTextSecondary}" Width="18" Height="18" Margin="0,2,8,0" />
                                <TextBlock Text="在线 KMS" FontSize="15" FontWeight="SemiBold" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <controls:MaterialButton Content="KMS 激活" Width="110" Height="36" Style="{StaticResource MaterialTonalButton}" Click="OnRunKms" />
                                <Border CornerRadius="{StaticResource CornerButton}" Margin="12,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10"
                                                          ShadowDepth="1"
                                                          Opacity="0.2"
                                                          Color="#22000000"
                                                          RenderingBias="Performance" />
                                    </Border.Effect>
                                    <controls:MaterialButton Content="卸载" Width="90" Height="36" Style="{StaticResource MaterialOutlinedButton}" Click="OnRunKmsUninstall" />
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </controls:MaterialCard>

                    <StackPanel Orientation="Horizontal">
                        <controls:MaterialIcon Geometry="{StaticResource IconInfo}" Fill="{StaticResource MaterialTextSecondary}" Width="18" Height="18" Margin="0,2,8,0" />
                        <TextBlock Text="关于" Style="{StaticResource MaterialSection}" />
                    </StackPanel>
                    <TextBlock Text="关于本软件及作者信息。" Style="{StaticResource MaterialSubtitle}" Margin="0,6,0,20" />

                    <controls:MaterialCard Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="120" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Border Width="120"
                                    Height="120"
                                    CornerRadius="{StaticResource CornerButton}"
                                    Background="{StaticResource MaterialSurfaceVariant}"
                                    BorderBrush="{StaticResource MaterialOutlineVariant}"
                                    BorderThickness="1"
                                    Margin="0,0,12,0"
                                    SnapsToDevicePixels="True">
                                <Border Width="118"
                                        Height="118"
                                        CornerRadius="{StaticResource CornerMedium}"
                                        ClipToBounds="True"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Image Width="118"
                                           Height="118"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Source="pack://application:,,,/MAS_GUI;component/Res/miku.jpg" />
                                </Border>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="世间自有尘寰在&#10;我亦独吟游且歌" Style="{StaticResource MaterialSubtitle}" TextWrapping="Wrap" FontWeight="Bold" />
                                <TextBlock Text="The world turns; I wander and sing." Style="{StaticResource MaterialSubtitle}" Margin="0,6,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,12,0,0">
                                <TextBlock Text="项目地址" Style="{StaticResource MaterialLabel}" />
                                <TextBlock Text="https://github.com/Amamiyashi0n/MAS-GUI" 
                                           Style="{StaticResource MaterialSubtitle}" 
                                           TextWrapping="Wrap" 
                                           Cursor="Hand"
                                           Foreground="{StaticResource MaterialPrimary}"
                                           MouseLeftButtonDown="OnProjectLinkClick" />
                            </StackPanel>
                        </Grid>
                    </controls:MaterialCard>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid x:Name="ProgressOverlay" Grid.RowSpan="2" Background="#80000000" Visibility="Collapsed">
            <controls:MaterialCard Width="320" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="24">
                <Grid>
                    <StackPanel x:Name="ProgressContent" HorizontalAlignment="Center">
                        <TextBlock x:Name="ProgressTitle" Text="TSforge全量激活中" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource MaterialTextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                        <TextBlock Text="请稍候完成运行…" FontSize="14" Foreground="{StaticResource MaterialTextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,24" />
                        <controls:MaterialProgressBar x:Name="ProgressBar" Width="48" Height="48" IsIndeterminate="True" HorizontalAlignment="Center" />
                    </StackPanel>
                    
                    <StackPanel x:Name="CompletionPanel" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <controls:MaterialIcon x:Name="CompletionIcon" Geometry="{StaticResource IconCheck}" Fill="{StaticResource MaterialPrimary}" Width="64" Height="64" Opacity="0" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <controls:MaterialIcon.RenderTransform>
                                <ScaleTransform x:Name="CompletionScale" ScaleX="0.6" ScaleY="0.6" />
                            </controls:MaterialIcon.RenderTransform>
                        </controls:MaterialIcon>
                        <TextBlock Text="已完成" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource MaterialTextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0" x:Name="CompletionText" />
                        <StackPanel x:Name="CompletionDetails" Opacity="0" Margin="0,0,0,24">
                            <TextBlock x:Name="WindowsResultText" FontSize="14" Foreground="{StaticResource MaterialTextSecondary}" TextAlignment="Center" TextWrapping="Wrap" Width="260" Margin="0,0,0,4" />
                            <TextBlock x:Name="OfficeResultText" FontSize="14" Foreground="{StaticResource MaterialTextSecondary}" TextAlignment="Center" TextWrapping="Wrap" Width="260" />
                        </StackPanel>
                        <controls:MaterialButton x:Name="CompletionCloseButton" Content="确定" Width="120" Height="40" Style="{StaticResource MaterialTonalButton}" Click="OnCloseCompletion" HorizontalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </controls:MaterialCard>
        </Grid>

        <controls:SponsorDialog x:Name="SponsorDialog" Grid.RowSpan="2" />
    </Grid>
    </Border>
</Window>
