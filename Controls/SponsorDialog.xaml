<UserControl x:Class="MAS_GUI.Controls.SponsorDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAS_GUI.Controls"
             Visibility="Collapsed">
    <Grid Background="#80000000" MouseLeftButtonDown="OnOverlayClick">
        <controls:MaterialCard x:Name="Card" Width="350" HorizontalAlignment="Center" VerticalAlignment="Center" MouseLeftButtonDown="OnCardClick" RenderTransformOrigin="0.5,0.5">
            <controls:MaterialCard.RenderTransform>
                <ScaleTransform x:Name="CardScale" ScaleX="0.8" ScaleY="0.8"/>
            </controls:MaterialCard.RenderTransform>
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title/Text -->
                <TextBlock Grid.Row="0" 
                           Text="软件好用吗？&#10;也许你能给予我一点小小的帮助？" 
                           Style="{StaticResource MaterialSection}"
                           FontSize="18"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Image -->
                <Border Grid.Row="1" 
                        CornerRadius="{StaticResource CornerMedium}" 
                        ClipToBounds="True"
                        Margin="0,0,0,20">
                    <Image Source="pack://application:,,,/MAS_GUI;component/Res/sponsor.png" 
                           Stretch="Uniform"/>
                </Border>

                <!-- Close Button -->
                <controls:MaterialButton Grid.Row="2" 
                                         Content="好的" 
                                         Style="{StaticResource MaterialTonalButton}"
                                         HorizontalAlignment="Stretch"
                                         Click="OnCloseClick"/>
            </Grid>
        </controls:MaterialCard>
    </Grid>
</UserControl>
